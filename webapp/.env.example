# Stripe Configuration
# Get these from https://dashboard.stripe.com/apikeys
#
# Pricing:
#   - First property license: $1,495 (one-time, 1 year)
#   - Additional properties: $295 each
#
# Setup Steps:
#   1. Create Stripe account at https://dashboard.stripe.com/register
#   2. Go to Products → Add Product
#   3. Create "Casino Economic Impact Calculator - Pro License" at $1,495
#   4. Copy the Price ID (starts with price_)
#   5. Add your keys below

# Secret key (starts with sk_live_ or sk_test_)
STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxx

# Price ID for first property license ($1,495)
# Create a product in Stripe Dashboard, then copy the Price ID (starts with price_)
STRIPE_PRICE_ID=price_xxxxxxxxxxxxxxxxxxxx

# Price ID for additional properties ($295) - for future use
# STRIPE_ADD_PROPERTY_PRICE_ID=price_xxxxxxxxxxxxxxxxxxxx

# Optional: Custom salt for license key generation
# LICENSE_SALT=your-custom-secret-salt
