  "_metadata": {
    "description": "Employment-based tax rates for economic impact modeling",
    "sources": {
      "suta": "US DOL ETA, Calendar Year 2024 Actual Average Employer Contribution Rates",
      "sdi_pfml": "State workforce agencies, EY, payroll provider compilations (2025)",
      "household": "BEA SAINC50 (personal current taxes) / SAINC4 (wages and salaries), 2024"
    },
    "methodology": {
      "payroll_taxes": "FICA employer (Social Security 6.2% on first $176,100 + Medicare 1.45% uncapped) + FUTA (0.6% on first $7,000) + SUTA (state avg rate on state wage base) + SDI/PFML where applicable. Applied to wages by effect type, with per-employee caps converted using average wage / FTE count.",
      "household_taxes": "BEA personal current taxes include federal/state/local income taxes, motor vehicle licenses, and personal property taxes. Ratio applied to wages by effect type. Does NOT include real estate property taxes or sales taxes (those are TOPI) or FICA (separate)."
    }
  },
